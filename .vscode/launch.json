{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against local dev server",
            "url": "http://localhost:${input:devServerPort}",
            "webRoot": "${workspaceFolder}"
        }
    ],
    "inputs": [
        {
            "id": "devServerPort",
            "type": "promptString",
            "description": "Local dev server port for this workspace, for example 5173 for Vite or 8080 for other dev servers.",
            "default": "8080"
        }
    ]
}
