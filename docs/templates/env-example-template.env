# Copy this file to .env for local Docker Compose runs.
# Fill only the keys required by the service you are running.

APP_DATA_DIR=/data

# Optional API keys. Leave blank for offline/local fallback behavior where supported.
OPENAI_API_KEY=
TRACKER_API_KEY=
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
FACEBOOK_ACCESS_TOKEN=

# Database example for stacks that use PostgreSQL.
DATABASE_URL=postgresql://app:app@app-db:5432/app
