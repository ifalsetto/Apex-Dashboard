# Public frontend config only. Leave Auth0 blank for local beta mode.
# API calls use relative /api in local dev and the public Worker in production.
# Override only with a backend/proxy URL, never a Tracker API URL.
VITE_API_BASE_URL=

# Optional public Auth0 application values. Do not put secrets here.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/
VITE_AUTH0_LOGOUT_URI=http://localhost:5173/
