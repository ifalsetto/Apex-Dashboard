# Optional server-side Tracker.gg integration.
# Keep the real value in a local `.env` file. Never expose it through VITE_*.
TRN_API_KEY=

# Browser origins allowed to call the backend directly.
# The containerized frontend normally uses same-origin Nginx proxying.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional host-port overrides when the defaults are already occupied.
APEX_FRONTEND_PORT=5173
APEX_BACKEND_PORT=8787
